shared.permanentHitbox = nil

local old
old = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()

    if method == "FireServer" and self.Name == "WeaponHitEvent" then
        local args = {...}

        if not shared.permanentHitbox and args[1] and typeof(args[1]) == "Instance" then
            shared.permanentHitbox = args[1]
            print("[PERMA] Saved permanent hitbox:", args[1]:GetFullName())
        end
    end

    return old(self, ...)
end)

