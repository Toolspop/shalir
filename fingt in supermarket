        autoMoney = v
    end
})

local function sortByDistance(list)
    local c = char(lp)
    local r = hrp(c)
    if not c or not r then return list end

    table.sort(list, function(a, b)
        return (a.Position - r.Position).Magnitude < (b.Position - r.Position).Magnitude
    end)

    return list
end

local function moveTo(targetPos)
    local c = char(lp)
    local h = hum(c)
    local r = hrp(c)
    if not c or not h or not r then return false end

    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true
    })

    path:ComputeAsync(r.Position, targetPos)

    if path.Status ~= Enum.PathStatus.Success then
        h:MoveTo(targetPos)
        return true
    end

    for _, wp in ipairs(path:GetWaypoints()) do
        if not autoMoney then return false end

        h:MoveTo(wp.Position)
        if wp.Action == Enum.PathWaypointAction.Jump then
            h.Jump = true
        end

        local t0 = tick()
        while (r.Position - wp.Position).Magnitude > 4 do
            task.wait(0.05)
            if not autoMoney then return false end
            if tick() - t0 > 2 then break end
        end
    end

    return true
end

task.spawn(function()
    while true do
        task.wait(0.1)
        if not autoMoney then continue end

        local c = char(lp)
        local r = hrp(c)
        local h = hum(c)
        if not c or not r or not h then continue end

        local folder = workspace:FindFirstChild("SpawnedCash")
        if not folder then continue end

        local hitboxes = {}
        for _, money in ipairs(folder:GetChildren()) do
            local hb = money:FindFirstChild("MoneyHitbox")
            if hb and hb:IsA("BasePart") then
                table.insert(hitboxes, hb)
            end
        end

        if #hitboxes == 0 then continue end

        hitboxes = sortByDistance(hitboxes)

        for _, hb in ipairs(hitboxes) do
            if not autoMoney then break end
            if not hb or not hb.Parent then continue end

            moveTo(hb.Position + Vector3.new(0, 2, 0))

            local t0 = tick()
            while hb and hb.Parent and tick() - t0 < 1.5 do
                task.wait(0.05)
            end
        end
    end
end)

