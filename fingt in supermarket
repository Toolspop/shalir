local function getNearestPlayer(maxDist)
    local c = char(lp)
    local r = hrp(c)
    if not c or not r then return end

    local nearest = nil
    local nearestDist = maxDist or 20

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= lp and plr.Character then
            local hrp2 = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp2 then
                local dist = (hrp2.Position - r.Position).Magnitude
                if dist < nearestDist then
                    nearest = plr
                    nearestDist = dist
                end
            end
        end
    end

    return nearest
end

local function hitPlayer(plr)
    if not plr or not plr.Character then return end

    local torso = plr.Character:FindFirstChild("LowerTorso")
    if not torso then return end

    local evt = getWeaponEvent()
    if not evt then return end

    evt:FireServer(torso)
end

task.spawn(function()
    while true do
        task.wait(0.1)

        if autoAttack then
            local target = getNearestPlayer(20)
            if target then
                hitPlayer(target)
            end
        end
    end
end)

