local function getWeaponEvent()
    local c = lp.Character
    if not c then return nil end

    for _, obj in ipairs(c:GetChildren()) do
        local evt = obj:FindFirstChild("WeaponHitEvent")
        if evt then
            return evt
        end
    end

    return nil
end

