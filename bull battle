    return p.Team ~= lp.Team
end

---------------------------------------------------------------------
-- NEAREST TARGET
---------------------------------------------------------------------

local nearestTarget = nil

local function updateNearest()
    local c = char(lp)
    local r = hrp(c)
    if not c or not r then nearestTarget = nil return end
    local best, dist = nil, math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= lp and enemy(p) then
            local tc = char(p)
            local tr = hrp(tc)
            if tc and tr then
                local d = (tr.Position - r.Position).Magnitude
                if d < dist then
                    dist = d
                    best = p
                end
            end
        end
    end
    nearestTarget = best
end

task.spawn(function()
    while true do
        task.wait(0.15)
        updateNearest()
    end
end)

local function nearest()
    return nearestTarget
end

