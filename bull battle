        SaveKey = true,
        GrabKeyFromSite = false,
        Key = {"Shalirus"}
    }
})

local Tab = Window:CreateTab("Main")

local farming = false
local loopRunning = false

Tab:CreateToggle({
    Name = "Фарм яиц (бесконечно)",
    CurrentValue = false,
    Callback = function(Value)
        farming = Value

        if not farming then
            return
        end

        if loopRunning then
            return
        end
        loopRunning = true

        local player = game.Players.LocalPlayer
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local hum = char:WaitForChild("Humanoid")

        local eggsFolder = workspace.Ignore.Easter2026.Eggs

        local platformsFolder = Instance.new("Folder", workspace)
        platformsFolder.Name = "GeneratedPlatforms"

        local function clearPlatforms()
            for _, v in ipairs(platformsFolder:GetChildren()) do
                if v:IsA("BasePart") then
                    v:Destroy()
                end
            end
        end

        local function createPlatform(position)
            local part = Instance.new("Part")
            part.Size = Vector3.new(8, 1, 8)
            part.Anchored = true
            part.Color = Color3.fromRGB(255, 200, 0)
            part.Position = position - Vector3.new(0, 3, 0)
            part.Parent = platformsFolder
            return part
        end

        local function walkThroughEgg(egg)
            if not farming then return end

            local offset = Vector3.new(0, 3, -3)
            hrp.CFrame = CFrame.new(egg.Position + offset, egg.Position)
            task.wait(0.2)

            hum:MoveTo(egg.Position)
            hum.MoveToFinished:Wait(2)
            task.wait(0.2)
        end

        -- Бесконечный цикл, пока farming = true
        while farming do
            clearPlatforms()

            for i = 1, 8 do
                if not farming then break end

                local egg = eggsFolder:FindFirstChild("Egg" .. i)
                if egg then
                    createPlatform(egg.Position)
                    walkThroughEgg(egg)
                end
            end

            clearPlatforms()

            if farming then
                hrp.CFrame = CFrame.new(-459, 10, 2042)
            end

            task.wait(1)
        end

        clearPlatforms()
        platformsFolder:Destroy()
        loopRunning = false
    end
})







