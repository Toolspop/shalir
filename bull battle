local function char(plr) return plr.Character end
local function hrp(c) return c and c:FindFirstChild("HumanoidRootPart") end
local function hum(c) return c and c:FindFirstChildOfClass("Humanoid") end

local function enemy(p)
    if not p.Team or not lp.Team then return true end
    return p.Team ~= lp.Team
end
local hb_on = false
local hb_size = Vector3.new(10,10,10)
local hb_transp = 0.7
local function setHitbox(c)
    local root = hrp(c)
    if not root then return end

    if hb_on then
        root.Size = hb_size
        root.Transparency = hb_transp
        root.CanCollide = false
    else
        root.Size = Vector3.new(2,2,1)
        root.Transparency = 0
        root.CanCollide = true
    end
end

local function refreshHitboxes()
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            local c = char(p)
            if c then setHitbox(c) end
        end
    end
end
Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c)
        task.wait(1)
        if hb_on then setHitbox(c) end
    end)
end)

local function nearest()
    local c = char(lp)
    local r = hrp(c)
    if not c or not r then return end

    local best, dist = nil, math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= lp and enemy(p) then
            local tc = char(p)
            local tr = hrp(tc)
            if tc and tr then
                local d = (tr.Position - r.Position).Magnitude
                if d < dist then
                    dist = d
                    best = p
                end
            end
        end
    end
    return best
end

local tp_on = false
local tp_offset = -6
local tp_speed = 0.25
local lay_on = true

Run.Heartbeat:Connect(function()
    if not tp_on then return end

    local t = nearest()
    if not t then return end

    local c = char(lp)
    local r = hrp(c)
    local h = hum(c)
    if not c or not r or not h then return end

    local tc = char(t)
    local tr = hrp(tc)
    if not tc or not tr then return end

    if lay_on then
        h:ChangeState(Enum.HumanoidStateType.Physics)
        r.CFrame = CFrame.new(r.Position) * CFrame.Angles(math.rad(90),0,0)
    end

    local goal = tr.CFrame * CFrame.new(0, tp_offset, 0)
    Tween:Create(r, TweenInfo.new(tp_speed, Enum.EasingStyle.Linear), {CFrame = goal}):Play()
end)


