---------------------------------------------------------------------
-- HITBOX (перенесено из отдельной вкладки)
---------------------------------------------------------------------

local hitboxEnabled = false
local hitboxSize = 5
local hitboxTransparency = 0.7
local hitboxColor = Color3.fromRGB(255, 0, 0)
local rainbowHitbox = false

local function applyHitbox(char)
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if hitboxEnabled then
        hrp.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
        hrp.Transparency = hitboxTransparency
        hrp.Color = hitboxColor
        hrp.Material = Enum.Material.Neon
        hrp.CanCollide = false
    else
        hrp.Size = Vector3.new(2, 2, 1)
        hrp.Transparency = 0
        hrp.Color = Color3.fromRGB(255, 255, 255)
        hrp.Material = Enum.Material.Plastic
        hrp.CanCollide = true
    end
end

local function updateAllHitboxes()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= lp then
            local c = char(plr)
            if c then applyHitbox(c) end
        end
    end
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(c)
        task.wait(1)
        if hitboxEnabled then applyHitbox(c) end
    end)
end)

task.spawn(function()
    while true do
        task.wait(0.3)
        if hitboxEnabled then
            updateAllHitboxes()
        end
    end
end)

task.spawn(function()
    local h = 0
    while true do
        task.wait(0.03)
        if rainbowHitbox and hitboxEnabled then
            h = (h + 0.003) % 1
            hitboxColor = Color3.fromHSV(h, 1, 1)
            updateAllHitboxes()
        end
    end
end)

tabCombat:CreateToggle({
